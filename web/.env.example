# Copy to .env at project root before running the backend.
# All settings honour pydantic-settings semantics (any case).

# ---- General ----
ENVIRONMENT=dev
DEBUG=true

# ---- Database ----
# Dev: matches docker-compose.dev.yml (postgres on :5433)
DATABASE_URL=postgresql+psycopg://openquant:openquant@localhost:5433/openquant
DB_ECHO=false

# ---- Auth ----
# REQUIRED in prod — generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-CHANGE-IN-PROD-min-32-chars-please-1234
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# ---- CORS (comma-separated in env, parsed as JSON list) ----
# CORS_ORIGINS=["http://localhost:5173","http://openquant.local"]
